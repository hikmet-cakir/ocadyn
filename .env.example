# Copy to .env and fill in your SMTP credentials.
# Docker Compose loads .env automatically from the project root.

# --- Gmail (recommended: App Password, not your login password) ---
# 1. Enable 2-Step Verification on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=you@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_FROM=you@gmail.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_SSL=false

# --- Outlook / Hotmail ---
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_USER=you@outlook.com
# MAIL_PASS=your-password
# MAIL_FROM=you@outlook.com

# --- Yandex ---
# MAIL_HOST=smtp.yandex.com
# MAIL_PORT=465
# MAIL_USER=you@yandex.com
# MAIL_PASS=your-password
# MAIL_FROM=you@yandex.com
# MAIL_SMTP_SSL=true
# MAIL_SMTP_STARTTLS=false

# Optional: disable email entirely
# MAIL_ENABLED=false

# Other stack settings (optional)
# JWT_SECRET=change-me
# INTERNAL_API_KEY=ocadyn-internal-dev-key
